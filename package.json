{
  "name": "portfolio_nextjs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "next dev",
    "dev:3001": "next dev -p 3001",
    "typecheck": "node scripts/ensure-next-routes-types.js && tsc --noEmit -p tsconfig.typecheck.json",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "node scripts/prepare-husky.js"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@grafana/faro-web-sdk": "^1.19.0",
    "@grafana/faro-web-tracing": "^1.19.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "12.23.12",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.540.0",
    "next": "15.5.18",
    "next-mdx-remote": "^6.0.0",
    "nodemailer": "^9.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^4.2.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "remark-gfm-mdx": "npm:remark-gfm@^4.0.0",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.21",
    "@eslint/eslintrc": "^3.3.1",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^8.0.3",
    "lint-staged": "^17.0.4",
    "postcss": "^8.5.14",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "glob": "10.5.0",
    "yaml": "2.8.4",
    "protobufjs": "7.5.8",
    "postcss": "8.5.14",
    "lodash": "4.18.1",
    "ajv": "6.15.0",
    "flatted": "3.4.2",
    "picomatch": "2.3.2",
    "minimatch": "3.1.5",
    "brace-expansion": "1.1.14"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
