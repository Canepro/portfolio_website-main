# Portfolio Website Environment Variables
# Copy this file to .env.local and fill in your values

# ======================
# Analytics (Optional)
# ======================
# Google Analytics tracking ID
# Get yours at: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ======================
# Grafana Monitoring (Optional)
# ======================
# Grafana Faro Frontend Observability
# Get your credentials at: https://grafana.com/products/cloud/
NEXT_PUBLIC_FARO_URL=https://your-faro-endpoint.grafana.net/collect
NEXT_PUBLIC_FARO_APP_NAME=portfolio-website

# ======================
# Rocket.Chat Live Chat (Optional)
# ======================
# Enable live chat widget
NEXT_PUBLIC_RC_ENABLED=0
# Your Rocket.Chat instance URL
NEXT_PUBLIC_RC_URL=https://your-instance.rocket.chat/livechat

# ======================
# Contact Form Email (Optional)
# ======================
# SMTP server configuration for contact form
CONTACT_SMTP_HOST=smtp.gmail.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=your-email@gmail.com
CONTACT_SMTP_PASS=your-app-password
CONTACT_TO=recipient@example.com
CONTACT_FROM=noreply@yourwebsite.com

# ======================
# GitHub API (Optional)
# ======================
# Personal access token for GitHub API
# Increases rate limits from 60 to 5000 requests/hour
# Create token at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ======================
# Development (Optional)
# ======================
# Set to 'development' or 'production'
NODE_ENV=development
